      </div>
      <h1 class="about-hero">
        <span>screensavers used to</span>
        <span>protect our screens.</span>
        <span data-sentence-start>today, our attention is</span>
        <span>what needs protection.</span>
        <canvas class="about-hero-canvas" aria-hidden="true"></canvas>
      </h1>
      <form id="waitlist-form" class="waitlist-form" novalidate>
        <label class="pill-field" data-adapt>
          <input type="email" name="email" placeholder="email" required autocomplete="email" inputmode="email" />
        </label>
        <label class="pill-field" data-adapt>
          <input type="tel" name="phone" placeholder="phone" required autocomplete="tel" inputmode="tel" />
        </label>
        <button type="submit"><span class="btn-label">join the waitlist</span></button>
        <p id="waitlist-status" class="waitlist-status" role="status" aria-live="polite" data-adapt></p>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    document.addEventListener('DOMContentLoaded', function() {
      const pageTwo = document.getElementById('page-two')!;
      // Boot the Eigenfield background sketch + luminance-adaptive text.
      if ((window as any).startEigenfield) (window as any).startEigenfield();
      if ((window as any).startLumAdapter) (window as any).startLumAdapter();
      if ((window as any).startPillMirror) (window as any).startPillMirror();
      if ((window as any).startHeroCanvas) (window as any).startHeroCanvas();

      // Staged intro: logo fades in, then the hero's typewriter runs, then
      // each form field fades in one after the previous finishes its fade.
      const logo = document.querySelector('.about-logo') as HTMLElement;
      const hero = document.querySelector('.about-hero') as HTMLElement;
      const fields = document.querySelectorAll<HTMLElement>('.waitlist-form .pill-field');
      const emailField = fields[0];
      const phoneField = fields[1];
      const submitBtn = document.querySelector('.waitlist-form button') as HTMLElement;
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Resolves when el's opacity transition finishes. Uses a timeout fallback
      // so a missed transitionend (CSS override, reduced motion) still advances.
      function onOpacityEnd(el: HTMLElement, cb: () => void) {
        let done = false;
        const handler = (e: Event) => {
          const te = e as TransitionEvent;
          if (te.propertyName !== 'opacity' || done) return;
          done = true;
          el.removeEventListener('transitionend', handler);
          cb();
        };
        el.addEventListener('transitionend', handler);
        setTimeout(() => { if (done) return; done = true; el.removeEventListener('transitionend', handler); cb(); }, 1400);
      }

      if (prefersReduced) {
        logo.classList.add('is-visible');
        emailField.classList.add('is-visible');
        phoneField.classList.add('is-visible');
        submitBtn.classList.add('is-visible');
        if ((window as any).startHeroTyping) (window as any).startHeroTyping();
      } else {
        // Give the eigenfield art a beat to settle before the logo fades in.
        setTimeout(() => {
          requestAnimationFrame(() => {
            logo.classList.add('is-visible');
            onOpacityEnd(logo, () => {
              if ((window as any).startHeroTyping) (window as any).startHeroTyping();
            });
          });
        }, 300);
        const markClipDirty = () => {
          if ((window as any).markMirrorClipDirty) (window as any).markMirrorClipDirty();
        };
        hero.addEventListener('herotypingcomplete', () => {
          emailField.classList.add('is-visible');
          markClipDirty();
          onOpacityEnd(emailField, () => {
            phoneField.classList.add('is-visible');
            markClipDirty();
            onOpacityEnd(phoneField, () => {
              submitBtn.classList.add('is-visible');
            });
          });
        }, { once: true });
      }

      // Fade out before navigating away (back button or link)
      window.addEventListener('pagehide', function() {
        pageTwo.style.animation = 'none';
        pageTwo.style.transition = 'opacity 0.4s ease-out';
        pageTwo.style.opacity = '0';
      });

      // Re-trigger fade-in when restored from bfcache
      window.addEventListener('pageshow', function(e) {
        if (e.persisted) {
          pageTwo.style.animation = 'none';
          pageTwo.style.opacity = '0';
          void pageTwo.offsetHeight;
          pageTwo.style.transition = 'opacity 1.2s ease-out';
          pageTwo.style.opacity = '1';
        }
      });

      const form = document.getElementById('waitlist-form') as HTMLFormElement;
      const status = document.getElementById('waitlist-status')!;
      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      function setStatus(text: string, kind: 'idle' | 'error' | 'success') {
        status.textContent = text;
        status.className = 'waitlist-status' + (kind === 'error' ? ' waitlist-status--error' : kind === 'success' ? ' waitlist-status--success' : '');
      }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const data = new FormData(form);
        const email = String(data.get('email') || '').trim();
        const phone = String(data.get('phone') || '').trim();

        if (!email || !phone) {
          setStatus('please fill in both fields.', 'error');
          return;
        }
        if (!supabase) {
          setStatus('waitlist is not configured yet.', 'error');
          return;
        }

        submit.disabled = true;
        setStatus('submitting…', 'idle');

        const { error } = await supabase.from('waitlist').insert({ email, phone });

        submit.disabled = false;
        if (error) {
          setStatus('something went wrong. try again.', 'error');
          return;
        }

        form.reset();
        setStatus('thank you for your attention. we\u2019ll be in touch.', 'success');
      });
    });
  </script>
</Base>
