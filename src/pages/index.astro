---
import Base from '../layouts/Base.astro';
---
<Base
  title="ScreenSavor"
  description="ScreenSavor transforms your screen into a space of restoration through generative art grounded in neuroscience."
  ogDescription="Your screen, restored. Generative art for attention, stillness, and presence."
>
  <div id="bg-canvas"></div>

  <div class="content">
    <section class="opening" data-sketch="torus">
      <div class="opening-text">
        <div class="wordmark" id="wordmark">
          <span class="wordmark-line ani">Screen</span>
          <span class="wordmark-line ani">Savor</span>
        </div>
        <div class="tagline ani">Your screen, restored.</div>
      </div>
      <div class="scroll-cue">Scroll</div>
    </section>

    <section data-sketch="flame">
      <div class="section-text ani-group">
        <h2 class="ani">What if your screen could calm you?</h2>
        <p class="ani">
          ScreenSavor creates living, generative environments that unfold in real time on the devices you already use. Not content to consume. Not tasks to complete. Just evolving form, color, and motion designed to restore your attention and settle your nervous system.
        </p>
        <p class="ani">
          Each piece responds to touch, rewards stillness, and works through the same aesthetic principles that make standing before a great painting feel like returning to yourself.
        </p>
      </div>
    </section>

    <section data-sketch="wave">
      <div class="section-text ani-group">
        <h2 class="ani">Coming soon</h2>

        <div class="product ani">
          <div class="product-num">01</div>
          <div class="product-body">
            <span class="product-label">Browser Extension</span>
            <h3>A new tab, reimagined</h3>
            <p>
              Replace the void of infinite search with a generative sanctuary. Each time you open a tab, a living artwork greets you.
            </p>
            <form class="signup" action="https://formspree.io/f/xeooqpvr" method="POST">
              <input type="email" name="email" placeholder="your@email.com" required />
              <input type="hidden" name="source" value="extension" />
              <button type="submit">Notify me</button>
            </form>
          </div>
        </div>

        <div class="divider ani"></div>

        <div class="product ani">
          <div class="product-num">02</div>
          <div class="product-body">
            <span class="product-label">Mobile App</span>
            <h3>A pocket sanctuary</h3>
            <p>
              For the moments you reach for your phone. Open ScreenSavor instead, and let a few breaths of living art reset your day.
            </p>
            <form class="signup" action="https://formspree.io/f/xeooqpvr" method="POST">
              <input type="email" name="email" placeholder="your@email.com" required />
              <input type="hidden" name="source" value="mobile" />
              <button type="submit">Join waitlist</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section data-sketch="torus">
      <div class="section-text ani-group">
        <h2 class="ani">Why it works</h2>
        <p class="ani">
          ScreenSavor is grounded in Attention Restoration Theory, neuroaesthetics, and sensorimotor regulation research. The generative systems are designed to produce soft fascination &mdash; a psychological state shown to replenish attentional resources and support emotional regulation.
        </p>
        <p class="ani">
          <a href="/about">Explore the research &rarr;</a>
        </p>
        <footer class="ani">
          <a href="mailto:clay@scrnsvr.art">clay@scrnsvr.art</a>
        </footer>
      </div>
    </section>
  </div>

  <script is:inline src="/main.js"></script>
</Base>
