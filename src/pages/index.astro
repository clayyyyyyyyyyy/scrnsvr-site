---
import Base from '../layouts/Base.astro';
---
<Base
  title="Sanctum"
  description="Sanctum transforms your screen into a space of restoration through generative art grounded in neuroscience."
  ogDescription="Your screen, restored. Generative art for attention, stillness, and presence."
>
  <div id="bg-canvas"></div>

  <div class="content">
    <section class="opening" data-sketch="torus">
      <div class="wordmark">Sanctum</div>
      <div class="tagline">Your screen, restored.</div>
      <div class="scroll-hint">scroll</div>
    </section>

    <section class="experience" data-sketch="flame">
      <div class="section-inner fade-in">
        <h2>What if your screen could calm you?</h2>
        <p>
          Sanctum creates living, generative environments that unfold in real time on the devices you already use. Not content to consume. Not tasks to complete. Just evolving form, color, and motion designed to restore your attention and settle your nervous system.
        </p>
        <p>
          Each piece responds to touch, rewards stillness, and works through the same aesthetic principles that make standing before a great painting feel like returning to yourself.
        </p>
      </div>
    </section>

    <section class="products" data-sketch="wave">
      <div class="section-inner fade-in">
        <h2>Where to find Sanctum</h2>

        <div class="product-cards">
          <div class="product-card">
            <span class="badge">Coming soon</span>
            <h3>Browser Extension</h3>
            <p>
              Replace your new tab with a generative sanctuary. Each time you open a tab, a living artwork greets you instead of the void of infinite search.
            </p>
            <form class="email-form" action="https://formspree.io/f/xeooqpvr" method="POST">
              <input type="email" name="email" placeholder="your@email.com" required />
              <input type="hidden" name="source" value="extension" />
              <button type="submit">Notify me</button>
            </form>
          </div>

          <div class="product-card">
            <span class="badge waitlist">Waitlist</span>
            <h3>Mobile App</h3>
            <p>
              A pocket sanctuary for the moments you reach for your phone. Open Sanctum instead, and let a few breaths of living art reset your day.
            </p>
            <form class="email-form" action="https://formspree.io/f/xeooqpvr" method="POST">
              <input type="email" name="email" placeholder="your@email.com" required />
              <input type="hidden" name="source" value="mobile" />
              <button type="submit">Join waitlist</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="science" data-sketch="torus">
      <div class="section-inner fade-in">
        <h2>Why it works</h2>
        <p>
          Sanctum is grounded in Attention Restoration Theory, neuroaesthetics, and sensorimotor regulation research. The generative systems are designed to produce soft fascination &mdash; a psychological state shown to replenish attentional resources and support emotional regulation.
        </p>
        <p>
          <a href="/about">Explore the research &rarr;</a>
        </p>
        <footer>
          <a href="mailto:clay@sanctum.art">clay@sanctum.art</a>
        </footer>
      </div>
    </section>
  </div>

  <script is:inline src="/main.js"></script>
</Base>
