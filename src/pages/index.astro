  <script is:inline src="/main.js"></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var logoDay = document.getElementById('logo');
      var logoNight = document.getElementById('logo-night');
      var overlay = document.querySelector('.logo-overlay');
      var circleDay = document.getElementById('circle');
      var circleNight = document.getElementById('circle-night');
      var zoomed = false;
      var currentlyNight = false;

      function getActiveLogo() {
        return currentlyNight ? logoNight : logoDay;
      }

      function getActiveCircle() {
        return currentlyNight ? circleNight : circleDay;
      }

      function getZoomParams() {
        var activeCircle = getActiveCircle();
        var circleRect = activeCircle.getBoundingClientRect();
        var cx = circleRect.left + circleRect.width / 2;
        var cy = circleRect.top + circleRect.height / 2;
        var circleRadius = Math.max(circleRect.width, circleRect.height) / 2;
        var viewDiag = Math.sqrt(
          window.innerWidth * window.innerWidth +
          window.innerHeight * window.innerHeight
        );
        return {
          cx: cx,
          cy: cy,
          scale: (viewDiag / circleRadius) * 1.2
        };
      }

      function reverseZoom() {
        var stored = sessionStorage.getItem('zoomParams');
        if (!stored) return;
        sessionStorage.removeItem('zoomParams');

        var params = JSON.parse(stored);

        // Start zoomed in with no transition and no fade-in
        overlay.style.transition = 'none';
        logoDay.style.animation = 'none';
        logoDay.style.opacity = '1';
        overlay.style.transformOrigin = params.cx + 'px ' + params.cy + 'px';
        overlay.style.transform = 'scale(' + params.scale + ')';

        // Force reflow, then animate back
        overlay.offsetHeight;
        overlay.style.transition = '';
        overlay.style.transform = 'scale(1)';
        zoomed = false;
      }

      // Handle both fresh load and bfcache restore
      reverseZoom();
      window.addEventListener('pageshow', function(e) {
        if (e.persisted) {
          // Reset overlay transition so forward zoom can animate again
          overlay.style.transition = '';
          overlay.style.transform = '';
          overlay.style.transformOrigin = '';
          reverseZoom();
        }
      });

      // Listen for night mode toggle from the cloud shader
      window.addEventListener('nightToggle', function(e) {
        currentlyNight = e.detail.isNight;
        if (currentlyNight) {
          logoDay.style.animation = 'none';
          logoDay.style.opacity = '0';
          logoNight.style.opacity = '1';
          logoDay.style.pointerEvents = 'none';
          logoNight.style.pointerEvents = 'auto';
        } else {
          logoDay.style.opacity = '1';
          logoNight.style.opacity = '0';
          logoDay.style.pointerEvents = 'auto';
          logoNight.style.pointerEvents = 'none';
        }
      });

      function triggerZoom() {
        if (zoomed) return;
        zoomed = true;

        var params = getZoomParams();
        overlay.style.transformOrigin = params.cx + 'px ' + params.cy + 'px';
        overlay.style.transform = 'scale(' + params.scale + ')';

        setTimeout(function() {
          sessionStorage.setItem('zoomParams', JSON.stringify(params));
          window.location.href = '/about';
        }, 1400);
      }

      function onLogoClick(e) {
        e.stopPropagation();
        e.preventDefault();
        triggerZoom();
      }

      logoDay.addEventListener('click', onLogoClick);
      logoDay.addEventListener('touchend', onLogoClick);
      logoNight.addEventListener('click', onLogoClick);
      logoNight.addEventListener('touchend', onLogoClick);
    });
  </script>
</Base>
